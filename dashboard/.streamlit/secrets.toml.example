# Copiar TODO este bloque en Streamlit Cloud → App → Settings → Secrets
# NO pegar un archivo .env (usa KEY=value). Aquí debe ser TOML: KEY = "valor"
#
# Main file del deploy: dashboard/app.py

DATA_SOURCE = "tidb"
DATA_MODE = "unificado"

TIDB_HOST = "gateway01.us-west-2.prod.aws.tidbcloud.com"
TIDB_PORT = 4000
TIDB_USER = "TU_USUARIO.root"
TIDB_PASS = "TU_PASSWORD_TIDB"
TIDB_DB = "emergencias"

# En Streamlit Cloud (Linux) usar esta ruta, o dejar vacío (el código usa certifi)
TIDB_SSL_CA = "/etc/ssl/certs/ca-certificates.crt"

# Solo si DATA_SOURCE = "local" (no aplica en la nube)
MYSQL_HOST = "127.0.0.1"
MYSQL_PORT = 3306
MYSQL_USER = "root"
MYSQL_PASSWORD = ""
MYSQL_DATABASE = "emergencias"
