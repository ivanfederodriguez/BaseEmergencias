# ============================================================
# Copiar a .env y completar con los valores reales.
# El archivo .env NO debe subirse a git (ya está en .gitignore).
# ============================================================

# Origen activo del dashboard: "local" o "tidb"
DATA_SOURCE=local

# --- MySQL local ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=emergencias

# --- TiDB Cloud Serverless ---
# Se obtienen en la consola: https://tidbcloud.com → Clusters → Connect
TIDB_HOST=gateway01.us-west-2.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=xxxxxxxx.root
TIDB_PASS=tu_password_tidb
TIDB_DB=emergencias
# En Mac suele ser /etc/ssl/cert.pem ; en Linux /etc/ssl/certs/ca-certificates.crt
TIDB_SSL_CA=/etc/ssl/cert.pem
